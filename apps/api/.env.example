# KWS API - environment variables
# All real values live in Railway. This file is committed and contains no secrets.
# See KWS-SEC-011.

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Supabase - eu-west-1 (Ireland), resolved region per DECISION_REGION_DIVERGENCE.md (Option B)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT RS256 (KWS-SEC-001) - HS256 is prohibited
# Provide PEM as base64 to avoid newline issues in Railway env
JWT_PRIVATE_KEY_PEM_B64=
JWT_PUBLIC_KEY_PEM_B64=
JWT_ISSUER=ws.kipkiren.co.ke
JWT_AUDIENCE=ws.kipkiren.co.ke
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Anthropic - DEDICATED KWS key (never share with Bongo / Ace Mtihani / etc.)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Kipkiren Pay (M-Pesa via LipaPlus) - never call Daraja directly (ADR-KWS-005)
KIPKIREN_PAY_BASE_URL=
KIPKIREN_PAY_API_KEY=
KIPKIREN_PAY_HMAC_SECRET=

# Paystack (cards)
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Cloudflare DNS (S6) - admin DNS management; feature 503s until the token is set
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Transactional email - ticket / proforma / payment notices to the client's
# registered address. Generic HTTPS provider (Resend-compatible): POST
# {from,to,subject,html,text} with a bearer key. Off until all 3 are set.
EMAIL_API_URL=
EMAIL_API_KEY=
EMAIL_FROM=

# Todoku SMS (S9-003) - base64 HMAC (NOT hex). Feature off until all 5 are set;
# template ULIDs are wired in src/services/notifications.ts (placeholders → TEMPLATE_NOT_READY)
TODOKU_API_BASE=
TODOKU_KWS_API_KEY=
TODOKU_KWS_HMAC_SECRET=
TODOKU_KWS_WEBHOOK_SECRET=
TODOKU_KWS_SENDER_ID=

# Agent autonomous DNS/SSL execution (S9-004/005). OFF by default and a hard
# safety interlock: even when true, an agent may only execute work covered by an
# approved proforma whose content hash still matches (agent-execution.ts). Chamia
# flips this per-client only after the Phase 1->2 gate. Accepts true/1.
AGENT_DNS_EXECUTION_ENABLED=false

# CORS - comma-separated origins (all portal domains)
ALLOWED_ORIGINS=https://ws.kipkiren.co.ke,https://admin.ws.kipkiren.co.ke,https://tasks.ws.kipkiren.co.ke
